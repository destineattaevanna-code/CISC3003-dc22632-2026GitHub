# ---------- Backend environment ----------
PORT=4000

# Upstream backend for paper-related APIs that we don't re-implement locally.
# Leave blank to disable upstream proxy (those endpoints will simply return 501).
UPSTREAM_API=http://47.83.174.214:8003

# ---------- SMTP for real email verification ----------
# Pick any provider and use an *app password* (not your login password).
#
# Example: Gmail with 2FA + App Password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your_account@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# SMTP_FROM="iSuperviz Team07 <your_account@gmail.com>"
#
# Example: QQ mail / 163 mail (common in mainland China)
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=yourid@qq.com
# SMTP_PASS=your_qq_authorization_code
# SMTP_FROM="iSuperviz Team07 <yourid@qq.com>"

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# If SMTP_* is not configured the server will fall back to "console mode",
# printing the verification code to the terminal so you can still test signup.

# JWT secret (used for password reset tokens)
JWT_SECRET=change_me_team07_cisc3003
